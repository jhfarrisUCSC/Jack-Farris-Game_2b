class Gameplay extends Phaser.Scene {
  constructor() {
    super("gameplayScrene");
    this.my = {sprite: {}};
    this.bodyX = 300;
    this.bodyY = 500;
    this.attacking = false;
    this.attackX = 500;
    this.attackY = 300;
  }

  preload() {
    this.load.setPath("./assets/");
    this.load.image("body","character_squareGreen.png");
    this.load.image("attack","background_tree.png");
    document.getElementById('description').innerHTML= '<h2>heroScene.js</h2>'
  }

  create() {
    let my = this.my;
    this.spaceKey =
    this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.SPACE);
    this.aKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.A);
    this.dKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.D);
    my.sprite.body = this.add.sprite(this.bodyX, this.bodyY, "body")
    my.sprite.attack = this.add.sprite(this.bodyX, this.bodyY, "attack")
    my.sprite.attack.visible = false;

    this.spaceKey.on('down', () => {
      if (this.attacking == false) {
        this.attackX = this.bodyX;
        this.attackY = this.bodyY;
        my.sprite.attack.x = this.attackX;
        my.sprite.attack.y = this.attackY;
        this.attacking = true;
        my.sprite.attack.visible = true;
      }
    })
  }

  update() {
    let my = this.my;
    if (this.aKey.isDown && (my.sprite.body.x > 0)) {
    this.bodyX -=5;
    }
    if (this.dKey.isDown && (my.sprite.body.x < 800)) {
      this.bodyX +=5;
    }
    my.sprite.body.x = this.bodyX;
    if (this.attacking == true) {
      this.attackY -= 5;
    }
    my.sprite.attack.y = this.attackY;
    if (my.sprite.attack.y <= 0) {
      my.sprite.attack.visible = false;
      this.attacking = false;
    }
  }
}
